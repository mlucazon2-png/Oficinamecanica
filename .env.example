APP_NAME="AutoTech Pro"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_LOCALE=pt_BR
APP_TIMEZONE=America/Fortaleza

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=autotech
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

OS_DEFAULT_MECANICO_EMAIL=jose@autotech.com

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@autotech.com"
MAIL_FROM_NAME="${APP_NAME}"
